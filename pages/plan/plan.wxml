<!-- pages/plan/plan.wxml — 辅食 -->
<view class="page-container">

  <!-- 筛选下拉框 -->
  <view class="filter-bar">
    <view class="filter-dropdown">
      <view class="filter-select {{showTabDropdown ? 'filter-select--open' : ''}}" style="{{currentCatStyle}}" bindtap="toggleTabDropdown">
        <text class="filter-select__prefix" style="{{currentCatStyle ? 'color:inherit;opacity:.75' : ''}}">分类:</text>
        <text class="filter-select__label">{{currentTabName}}</text>
        <text class="filter-select__arrow {{showTabDropdown ? 'filter-select__arrow--open' : ''}}" style="{{currentCatStyle ? 'color:inherit;opacity:.7' : ''}}">▾</text>
      </view>
      <view class="filter-options" wx:if="{{showTabDropdown}}">
        <view
          class="filter-option filter-option--{{item.id}} {{currentTab === item.id ? 'filter-option--active' : ''}}"
          wx:for="{{tabList}}"
          wx:key="id"
          bindtap="selectTab"
          data-id="{{item.id}}"
          style="{{catColorMap[item.id] && currentTab === item.id ? 'background:' + catColorMap[item.id].bg + ';color:' + catColorMap[item.id].text + ';' : ''}}"
        >
          <view class="filter-option__dot" wx:if="{{catColorMap[item.id]}}" style="background:{{catColorMap[item.id].text}}"></view>
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="filter-dropdown">
      <view class="filter-select filter-select--{{currentStatus}} {{showStatusDropdown ? 'filter-select--open' : ''}}" bindtap="toggleStatusDropdown">
        <text class="filter-select__prefix">状态:</text>
        <text class="filter-select__label">{{currentStatusName}}</text>
        <text class="filter-select__arrow {{showStatusDropdown ? 'filter-select__arrow--open' : ''}}">▾</text>
      </view>
      <view class="filter-options" wx:if="{{showStatusDropdown}}">
        <view
          class="filter-option filter-option--{{item.id}} {{currentStatus === item.id ? 'filter-option--active' : ''}}"
          wx:for="{{statusList}}"
          wx:key="id"
          bindtap="selectStatus"
          data-id="{{item.id}}"
        >
          <view class="filter-option__dot" wx:if="{{item.color}}" style="background:{{item.color}}"></view>
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 点击外部关闭下拉 -->
  <view class="filter-outside-mask" wx:if="{{showTabDropdown || showStatusDropdown}}" bindtap="closeDropdowns" catchtouchmove="noop"></view>

  <!-- 食物网格 -->
  <scroll-view class="food-scroll" scroll-y style="height:{{foodScrollHeight}}px">
    <view class="food-grid">
      <view
        class="food-card"
        style="background:{{food.catColor}}"
        wx:for="{{displayFoods}}"
        wx:key="id"
        wx:for-item="food"
        bindtap="showFoodDetail"
        data-id="{{food.id}}"
      >
        <!-- 彩色区域：图标 + 名称 + 进度点 -->
        <view class="food-card__top">
          <image wx:if="{{food.localIconPath}}" class="food-card__icon" src="{{food.localIconPath}}" mode="aspectFit"></image>
          <image wx:elif="{{food.iconUrl}}" class="food-card__icon" src="{{food.iconUrl}}" mode="aspectFit"></image>
          <text wx:else class="food-card__emoji">{{food.emoji}}</text>
          <text class="food-card__name">{{food.name}}</text>
          <view class="progress-dots">
            <view class="progress-dot {{food.status === 'passed' ? 'progress-dot--safe' : food.status === 'allergy' ? 'progress-dot--danger' : food.dayIndex >= 1 ? 'progress-dot--filled' : ''}}"></view>
            <view class="progress-dot {{food.status === 'passed' ? 'progress-dot--safe' : food.status === 'allergy' ? 'progress-dot--danger' : food.dayIndex >= 2 ? 'progress-dot--filled' : ''}}"></view>
            <view class="progress-dot {{food.status === 'passed' ? 'progress-dot--safe' : food.status === 'allergy' ? 'progress-dot--danger' : food.dayIndex >= 3 ? 'progress-dot--filled' : ''}}"></view>
          </view>
        </view>
        <!-- 灰色底部区域：营养标签 -->
        <view class="food-card__bottom">
          <text class="food-card__bottom-text">{{food.bottomLabel}}</text>
        </view>
      </view>
      <!-- 末尾追加自定义食物格子 -->
      <view class="food-card food-card--add" bindtap="addCustomFood">
        <view class="food-card__top food-card__top--add">
          <text class="food-card__emoji food-card__emoji--add">＋</text>
          <text class="food-card__name">自定义食物</text>
        </view>
        <view class="food-card__bottom">
          <text class="food-card__bottom-text">点击添加</text>
        </view>
      </view>
    </view>
    <view class="scroll-bottom-spacer"></view>
  </scroll-view>

  <!-- ===== 食物详情面板（position:fixed）===== -->
  <view class="detail-mask {{showFoodDetail ? 'detail-mask--show' : ''}}" wx:if="{{renderFoodDetail}}" bindtap="closeFoodDetail" catchtouchmove="noop"></view>
  <view class="detail-panel {{showFoodDetail ? 'detail-panel--show' : ''}}" wx:if="{{renderFoodDetail}}" catchtouchmove="noop" bindtouchstart="onDetailDragStart" bindtouchend="onDetailDragEnd">
    <view class="detail-panel__top">
      <view class="panel-handle" catchtouchstart="onDetailDragStart" catchtouchend="onDetailDragEnd"></view>
      <view class="detail-panel__header" catchtouchstart="onDetailDragStart" catchtouchend="onDetailDragEnd">
        <view class="detail-panel__title-row">
          <image wx:if="{{detailFood.localIconPath}}" class="detail-panel__food-icon" src="{{detailFood.localIconPath}}" mode="aspectFit"></image>
          <image wx:elif="{{detailFood.iconUrl}}" class="detail-panel__food-icon" src="{{detailFood.iconUrl}}" mode="aspectFit"></image>
          <text wx:else class="detail-panel__food-emoji">{{detailFood.emoji}}</text>
          <view class="detail-panel__title-info">
            <text class="detail-panel__food-name">{{detailFood.name}}</text>
            <view class="detail-panel__status detail-panel__status--{{detailFood.status}}">
              <text>{{detailFood.statusText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <scroll-view scroll-y="{{true}}" class="detail-panel__records" style="height:{{detailScrollHeight}}px">
      <view style="padding: 0 30rpx">
        <view class="detail-record" wx:for="{{detailRecords}}" wx:key="dateStr">
          <view class="detail-record__main">
            <view class="detail-record__date">{{item.dateStr}}</view>
            <view class="detail-record__info">
              <text class="detail-record__time">{{item.timesStr}}</text>
              <view class="detail-record__reaction detail-record__reaction--{{item.reactionClass}}" wx:if="{{item.reactionClass !== 'normal'}}">
                <text>{{item.reaction}}</text>
              </view>
            </view>
          </view>
          <view class="detail-record__delete" catchtap="onDeleteDetailRecord" data-date="{{item.dateStr}}" data-count="{{item.times.length}}">
            <image src="/static/icons/trash.svg" class="detail-record__delete-icon" mode="aspectFit"></image>
          </view>
        </view>
        <view class="detail-empty" wx:if="{{detailRecords.length === 0}}">
          <text>暂无记录</text>
        </view>
      </view>
      <view class="scroll-bottom-spacer"></view>
    </scroll-view>
  </view>

</view>

<!-- 记录辅食覆盖层 -->
<record-sheet show="{{showRecordSheet}}" bind:close="onRecordSheetClose" bind:saved="onRecordSaved" />

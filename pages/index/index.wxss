/* pages/index/index.wxss — 首页样式 */

/* ===== 头部 ===== */
.header {
  margin: 24rpx 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.header-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid var(--color-primary-light);
  flex-shrink: 0;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.header-name {
  font-size: 22px;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
}

.header-birthday {
  font-size: 13px;
  color: var(--color-text-secondary);
  display: block;
}

.header-date-text {
  font-size: 13px;
  color: var(--color-text-secondary);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.header-age {
  font-size: 15px;
  color: var(--color-primary);
  font-weight: 600;
  display: block;
}

/* ===== 宝宝切换弹窗 ===== */
.switcher-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.switcher-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.switcher-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  pointer-events: none;
}

.switcher-panel--show {
  transform: translateY(0);
  pointer-events: auto;
}

.switcher-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.switcher-panel__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.switcher-panel__close {
  font-size: 24px;
  color: var(--color-text-hint);
  padding: 8rpx;
}

.switcher-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.switcher-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  gap: 16rpx;
  border: 2rpx solid transparent;
}

.switcher-item--active {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.switcher-item__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.switcher-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.switcher-item__name {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.switcher-item__age {
  font-size: 13px;
  color: var(--color-text-secondary);
}

.switcher-item__check {
  font-size: 14px;
  color: var(--color-primary);
  font-weight: 600;
}

.switcher-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  border: 2rpx dashed var(--color-border);
}

.switcher-add__icon {
  font-size: 20px;
  color: var(--color-primary);
}

.switcher-add__text {
  font-size: 15px;
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 快捷入口 ===== */
.quick-entries {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 0;
}

.quick-entry {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--border-radius-lg);
  padding: 24rpx 12rpx;
  gap: 8rpx;
  box-shadow: var(--shadow-sm);
}

.quick-entry-icon {
  font-size: 28px;
  color: #fff;
}

.quick-entry-label {
  font-size: 13px;
  color: #fff;
  font-weight: 500;
}

/* ===== 排敏进度 ===== */
.progress-card {
  margin: 20rpx 24rpx 0;
}

.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-header__right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-count {
  font-size: 13px;
  color: var(--color-text-hint);
}

.share-report-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-report-btn--hover {
  opacity: 0.7;
}

.share-report-btn__icon {
  width: 44rpx;
  height: 44rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: var(--color-bg);
  border-radius: 100rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 100rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 13px;
  color: var(--color-primary);
  font-weight: 600;
  min-width: 40rpx;
}

/* ===== 安全/过敏入口 ===== */
.safety-boxes {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.safety-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  border-radius: var(--border-radius-base);
  gap: 4rpx;
}

.safety-box--safe {
  background: var(--color-success-light);
  border: 2rpx solid var(--color-success);
}

.safety-box--testing {
  background: var(--color-warning-light);
  border: 2rpx solid var(--color-warning);
}

.safety-box--preliminary {
  background: var(--color-warning-light);
  border: 2rpx solid var(--color-warning);
}

.safety-box--danger {
  background: var(--color-danger-light);
  border: 2rpx solid var(--color-danger);
}

.safety-box__icon {
  font-size: 20px;
  font-weight: 700;
}

.safety-box--safe .safety-box__icon { color: var(--color-success); }
.safety-box--preliminary .safety-box__icon { color: var(--color-warning); }
.safety-box--testing .safety-box__icon { color: var(--color-warning); }
.safety-box--danger .safety-box__icon { color: var(--color-danger); }

.safety-box__label {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.safety-box__count {
  font-size: 12px;
  color: var(--color-text-hint);
}

/* ===== 状态说明入口 ===== */
.status-explain-btn {
  margin-top: 16rpx;
  text-align: center;
}

.status-explain-btn text {
  font-size: 12px;
  color: var(--color-text-hint);
  text-decoration: underline;
}

/* ===== 过敏排查入口 ===== */
.allergy-trace-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFF2F0;
  border: 2rpx solid #FFCCC7;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  margin: 16rpx 24rpx 20rpx;
}

.allergy-trace-entry__icon {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}

.allergy-trace-entry__text {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.allergy-trace-entry__title {
  font-size: 15px;
  font-weight: 600;
  color: #CF1322;
}

.allergy-trace-entry__sub {
  font-size: 13px;
  color: #FF7875;
}

/* ===== 状态说明列表 ===== */
.status-explain-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 8rpx;
}

.status-explain-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.status-explain-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.status-explain-dot--passed { background: var(--color-success); }
.status-explain-dot--preliminary { background: var(--color-warning); }
.status-explain-dot--testing { background: var(--color-warning); }
.status-explain-dot--allergy { background: var(--color-danger); }

.status-explain-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.status-explain-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.status-explain-desc {
  font-size: 13px;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ===== 今天可以吃什么 ===== */
.suggestion-card {
  margin: 20rpx 24rpx 0;
}

.suggestion-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.suggestion-hint {
  font-size: 12px;
  color: var(--color-text-hint);
  background: var(--color-bg);
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
}

.suggestion-groups {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.suggestion-group__label {
  font-size: 12px;
  color: var(--color-text-hint);
  min-width: 60rpx;
  flex-shrink: 0;
}

.suggestion-group__foods {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 排敏任务 / 今日搭配 / 新食物 — 区块背景色区分 */
.suggestion-group--testing .suggestion-group__foods {
  background: #FFF7E6;
  border-radius: 12rpx;
  padding: 16rpx;
}
.suggestion-group--next_try .suggestion-group__foods {
  background: #F0FFF4;
  border-radius: 12rpx;
  padding: 16rpx;
}

/* 每个食物条目：横向布局 */
.suggestion-food {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.suggestion-food__left {
  flex-shrink: 0;
}

.suggestion-food__emoji {
  font-size: 52rpx;
  line-height: 1;
}

.suggestion-food__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.suggestion-food__top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.suggestion-food__name {
  font-size: 15px;
  color: var(--color-text-primary);
  font-weight: 600;
}

.suggestion-food__desc {
  font-size: 11px;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.suggestion-food__badge {
  padding: 2rpx 10rpx;
  border-radius: 100rpx;
  font-size: 10px;
  font-weight: 600;
}

.suggestion-food__badge--testing {
  background: var(--color-warning);
  color: #fff;
}

.suggestion-food__badge--new {
  background: #52C41A;
  color: #fff;
}

/* ===== 安全/过敏食物列表面板 ===== */
.food-list-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1001;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.food-list-panel--show {
  opacity: 1;
  pointer-events: auto;
}

.food-list-panel__inner {
  width: 100%;
  height: 85vh;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(200rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.food-list-panel__inner--show {
  transform: translateY(0);
}

.food-list-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.food-list-panel__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.food-list-panel__close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg);
  flex-shrink: 0;
}

.food-list-panel__close text {
  font-size: 28rpx;
  color: var(--color-text-hint);
  line-height: 1;
}

.food-list-panel__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.food-list-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.food-list-item__emoji {
  font-size: 56rpx;
  line-height: 1;
}

.food-list-item__icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
}

.food-list-item__name {
  font-size: 12px;
  color: var(--color-text-primary);
  text-align: center;
}

.food-list-item--allergy .food-list-item__name {
  color: var(--color-danger);
}

.food-list-item--preliminary .food-list-item__name {
  color: var(--color-warning);
}

/* ===== 当前排敏中 ===== */
.testing-section {
  margin-top: 24rpx;
}

.testing-scroll {
  width: 100%;
}

.testing-list {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
  gap: 16rpx;
  white-space: nowrap;
}

.testing-item {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  background: var(--color-white);
  border-radius: var(--border-radius-lg);
  padding: 16rpx 20rpx;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.testing-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.testing-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.testing-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.testing-days {
  font-size: 12px;
  color: var(--color-text-hint);
}

.testing-progress-bar {
  width: 120rpx;
  height: 6rpx;
  background: var(--color-bg);
  border-radius: 100rpx;
  overflow: hidden;
  margin-top: 4rpx;
}

.testing-progress-fill {
  height: 100%;
  background: var(--color-warning);
  border-radius: 100rpx;
  transition: width 0.3s ease;
}

/* ===== 过敏食物 ===== */
.allergy-section {
  margin: 20rpx 24rpx 0;
}

.allergy-count {
  font-size: 12px;
}

.allergy-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.allergy-tag {
  padding: 8rpx 20rpx;
  background: var(--color-danger-light);
  color: var(--color-danger);
  border-radius: 100rpx;
  font-size: 13px;
}

/* ===== 今日建议 ===== */
.suggestion-section {
  margin-top: 24rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
  gap: 16rpx;
  white-space: nowrap;
  overflow-x: auto;
}

.suggestion-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-white);
  border-radius: var(--border-radius-lg);
  padding: 20rpx 16rpx;
  gap: 10rpx;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
  width: 180rpx;
}

.suggestion-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
}

.suggestion-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  text-align: center;
}

.suggestion-cat {
  font-size: 11px;
  color: var(--color-text-hint);
  display: block;
}

.suggestion-reason {
  font-size: 11px;
  color: var(--color-primary);
  display: block;
  background: var(--color-primary-light);
  padding: 2rpx 10rpx;
  border-radius: 100rpx;
}

/* ===== 切换面板中的圆点 ===== */
.switcher-item__dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--color-primary);
  border-radius: 50%;
  flex-shrink: 0;
}

.switcher-item__right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: auto;
}

.switcher-item__edit {
  font-size: 13px;
  color: var(--color-primary, #FF9A56);
  padding: 8rpx 16rpx;
}

.switcher-item__delete {
  font-size: 13px;
  color: var(--color-danger);
  padding: 8rpx 16rpx;
}

/* ===== 编辑面板（添加宝宝） ===== */
.edit-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1001;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.edit-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.edit-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  z-index: 1002;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
  pointer-events: none;
}

.edit-panel--show {
  transform: translateY(0);
  pointer-events: auto;
}

.edit-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.edit-panel__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.edit-panel__close {
  font-size: 18px;
  color: var(--color-text-hint);
  padding: 8rpx;
}

.avatar-field {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-primary-light);
}

.avatar-btn {
  font-size: 14px;
  color: var(--color-primary);
  font-weight: 500;
}

.edit-field {
  margin-bottom: 20rpx;
}

.edit-field__label {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.edit-field__input {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 24rpx 24rpx;
  font-size: 16px;
  color: var(--color-text-primary);
  width: 100%;
  height: 80rpx;
  box-sizing: border-box;
}

.edit-field__picker {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx 20rpx;
  font-size: 14px;
  color: var(--color-text-primary);
}

.save-btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 16px;
  padding: 24rpx;
  margin-top: 8rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

/* ===== 家庭邀请加入弹窗 ===== */
.join-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1001;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.join-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.join-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(150rpx + env(safe-area-inset-bottom));
  background: var(--color-white);
  border-radius: 32rpx;
  padding: 0 36rpx 36rpx;
  z-index: 1002;
  transform: translateY(calc(100% + 160rpx));
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.28s ease;
  display: flex;
  flex-direction: column;
  text-align: center;
  opacity: 0;
  box-sizing: border-box;
  max-height: 86vh;
  overflow: hidden;
}

.join-modal--show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.join-modal__emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  line-height: 1;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.join-modal__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  display: block;
  flex-shrink: 0;
}

.join-modal__desc {
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 28rpx;
  display: block;
  flex-shrink: 0;
}

.join-modal__btns {
  display: flex;
  gap: 20rpx;
  width: 100%;
  flex-shrink: 0;
}

.join-modal__cancel {
  flex: 1;
  padding: 24rpx;
  border-radius: 100rpx;
  background: var(--color-bg);
  color: var(--color-text-secondary);
  font-size: 15px;
  text-align: center;
  font-weight: 500;
}

.join-modal__confirm {
  flex: 1.5;
  padding: 24rpx;
  border-radius: 100rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 15px;
  text-align: center;
  font-weight: 600;
}

/* ===== 添加/编辑宝宝表单里的性别 / 喂养方式按钮 ===== */
.baby-pill-row {
  display: flex;
  gap: 16rpx;
}
.baby-pill {
  flex: 1;
  min-height: 92rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #EDE3DC;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 8rpx;
  transition: all 0.18s;
}
.baby-pill__emoji {
  font-size: 40rpx;
  line-height: 1;
}
.baby-pill__text {
  font-size: 28rpx;
  font-weight: 500;
  color: #5A4A42;
}
.baby-pill--active-boy {
  background: linear-gradient(135deg, #E3F2FD 0%, #90CAF9 100%);
  border-color: #42A5F5;
  box-shadow: 0 4rpx 14rpx rgba(66, 165, 245, 0.25);
}
.baby-pill--active-boy .baby-pill__text {
  color: #1565C0;
  font-weight: 600;
}
.baby-pill--active-girl {
  background: linear-gradient(135deg, #FCE4EC 0%, #F48FB1 100%);
  border-color: #EC407A;
  box-shadow: 0 4rpx 14rpx rgba(236, 64, 122, 0.22);
}
.baby-pill--active-girl .baby-pill__text {
  color: #AD1457;
  font-weight: 600;
}
.baby-pill--active-feed {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFCC80 100%);
  border-color: #FF8C69;
  box-shadow: 0 4rpx 14rpx rgba(255, 140, 105, 0.25);
}
.baby-pill--active-feed .baby-pill__text {
  color: #D84315;
  font-weight: 600;
}

/* ===== 今日推荐（紧凑版） ===== */
.reco-card {
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
}
.reco-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.reco-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
}
.reco-adopt {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  background: var(--color-primary);
  border-radius: 100rpx;
}
.reco-adopt--hover { opacity: 0.75; }
.reco-adopt__icon {
  color: #fff;
  font-size: 11px;
  font-weight: 700;
}
.reco-adopt__text {
  color: #fff;
  font-size: 12px;
  font-weight: 500;
}
.reco-groups {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.reco-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.reco-group__label {
  font-size: 11px;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  width: 96rpx;
  padding: 4rpx 0;
}
.reco-group__label--testing { color: var(--color-warning); font-weight: 600; }
.reco-group__label--safe_combo { color: var(--color-success); font-weight: 600; }
.reco-group__label--next_try { color: var(--color-primary); font-weight: 600; }
.reco-chips {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  flex: 1;
}
.reco-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx 6rpx 8rpx;
  background: var(--color-bg);
  border-radius: 100rpx;
}
.reco-chip--testing { background: var(--color-warning-light); }
.reco-chip--safe_combo { background: var(--color-success-light); }
.reco-chip--next_try { background: var(--color-primary-light); }
.reco-chip__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
.reco-chip__emoji {
  font-size: 18px;
  line-height: 1;
}
.reco-chip__name {
  font-size: 12px;
  color: var(--color-text-primary);
}

<!-- pages/settings/settings.wxml — 设置页 -->
<page-meta page-style="{{showShareReport ? 'overflow: hidden;' : ''}}"></page-meta>
<view class="page-container">

  <view class="settings-content">

    <!-- ===== 完善宝宝资料 · 生长曲线钩子(功能开发中,过审后再放出) =====
    <view class="feature-card feature-card--growth" bindtap="openBabyProfile" hover-class="feature-card--hover">
      <view class="feature-card__icon">📈</view>
      <view class="feature-card__body">
        <text class="feature-card__title">完善宝宝资料</text>
        <text class="feature-card__desc">出生身高体重、家族过敏史 · 解锁生长曲线</text>
      </view>
      <text class="feature-card__arrow">›</text>
    </view>
    -->


    <!-- ===== 家庭协作 ===== -->
    <view class="feature-card">
      <view class="feature-card__icon">👨‍👩‍👧</view>
      <view class="feature-card__body">
        <text class="feature-card__title">家庭协作</text>
        <text class="feature-card__desc">和家人一起记录宝宝的辅食日常</text>
      </view>
      <button
        class="feature-card__btn"
        open-type="share"
        bindtap="inviteFamily"
        hover-class="feature-card__btn--hover"
      >邀请家人</button>
    </view>

    <!-- ===== 功能列表 ===== -->
    <view class="menu-group">
      <view class="menu-item" bindtap="openShareReport" hover-class="menu-item--hover">
        <view class="menu-item__icon menu-item__icon--orange">
          <text>📊</text>
        </view>
        <text class="menu-item__text">分享排敏报告</text>
        <text class="menu-item__arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="openAbout" hover-class="menu-item--hover">
        <view class="menu-item__icon menu-item__icon--blue">
          <text>ℹ️</text>
        </view>
        <text class="menu-item__text">关于</text>
        <text class="menu-item__arrow">›</text>
      </view>
    </view>

    <!-- ===== 关于弹窗 ===== -->
    <view class="about-mask {{showAbout ? 'about-mask--show' : ''}}" wx:if="{{renderAbout}}" bindtap="closeAbout"></view>
    <view
      class="about-panel {{showAbout ? 'about-panel--show' : ''}}"
      wx:if="{{renderAbout}}"
      catchtouchmove="noop"
      bindtouchstart="onAboutDragStart"
      bindtouchend="onAboutDragEnd"
    >
      <view class="about-panel__handle"></view>
      <view class="about-panel__header">
        <text class="about-panel__title">关于呀咪宝宝辅食</text>
      </view>

      <view class="about-section">
        <text class="about-section__label">产品简介</text>
        <text class="about-section__text">专注婴儿辅食记录与排敏管理。帮助家长记录每次辅食、追踪可疑过敏食物、一目了然地查看宝宝的排敏进度。</text>
      </view>

      <view class="about-section">
        <text class="about-section__label">版本</text>
        <text class="about-section__text">v1.0.0</text>
      </view>

      <view class="about-section">
        <text class="about-section__label">联系邮箱</text>
        <text class="about-section__text about-section__text--copy" bindtap="copyAboutEmail">13026334211@163.com</text>
      </view>

      <view class="about-section" wx:if="{{oaAvailable}}">
        <text class="about-section__label">关注公众号</text>
        <text class="about-section__text">关注「圆爸圆妈养娃记」获取育儿干货,反馈与合作也可以在公众号留言</text>
        <official-account bindload="onOaLoad" binderror="onOaError"></official-account>
      </view>

      <view class="about-section">
        <text class="about-section__label">协议</text>
        <view class="about-link-row">
          <text class="about-link" bindtap="openUserAgreement">《用户协议》</text>
          <text class="about-link" bindtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <view class="about-section about-section--disclaimer">
        <text class="about-section__disclaimer">本工具仅供家庭辅食记录,不能替代医生诊断。如宝宝出现过敏反应,请及时就医。</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="clearCache" hover-class="menu-item--hover">
        <view class="menu-item__icon menu-item__icon--red">
          <text>🗑</text>
        </view>
        <text class="menu-item__text menu-item__text--danger">清除缓存</text>
        <text class="menu-item__arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="deleteAccount" hover-class="menu-item--hover">
        <view class="menu-item__icon menu-item__icon--red">
          <text>⚠️</text>
        </view>
        <text class="menu-item__text menu-item__text--danger">注销账号</text>
        <text class="menu-item__arrow">›</text>
      </view>
    </view>

    <view class="version-text">呀咪宝宝辅食 v1.0.0</view>

  </view>
</view>

<!-- 分享报告弹窗 -->
<share-report id="shareReport" show="{{showShareReport}}" bind:close="onShareReportClose" />

<!-- 记录辅食覆盖层 -->
<record-sheet show="{{showRecordSheet}}" bind:close="onRecordSheetClose" bind:saved="onRecordSaved" />

<!-- 协议弹窗 -->
<view class="legal-modal-mask {{showLegalModal ? 'legal-modal-mask--show' : ''}}" wx:if="{{renderLegalModal}}" bindtap="closeLegalModal" catchtouchmove="noop"></view>
<view class="legal-modal {{showLegalModal ? 'legal-modal--show' : ''}}" wx:if="{{renderLegalModal}}" catchtouchmove="noop" bindtouchstart="onLegalModalDragStart" bindtouchend="onLegalModalDragEnd">
  <view class="legal-modal__handle"></view>
  <view class="legal-modal__header">
    <text class="legal-modal__title">{{legalTitle}}</text>
  </view>
  <scroll-view scroll-y class="legal-modal__content">
    <text class="legal-modal__intro">{{legalIntro}}</text>
    <view class="legal-section" wx:for="{{legalSections}}" wx:key="title">
      <text class="legal-section__title">{{index + 1}}. {{item.title}}</text>
      <view class="legal-section__item" wx:for="{{item.items}}" wx:for-item="line" wx:for-index="lineIndex" wx:key="*this">
        <text class="legal-section__dot">{{lineIndex + 1}}</text>
        <text class="legal-section__text">{{line}}</text>
      </view>
    </view>
  </scroll-view>
  <view class="legal-modal__footer">
    <view class="legal-modal__btn" bindtap="closeLegalModal">我已了解</view>
  </view>
</view>

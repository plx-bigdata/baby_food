/* pages/settings/settings.wxss — 设置页样式 */

.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 160rpx;
}

/* ===== 内容区 ===== */
.settings-content {
  padding: 32rpx 24rpx 0;
}

/* ===== 家庭协作主卡片 ===== */
.feature-card {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #FFF1EA 0%, #FFE4D9 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  pointer-events: none;
}

.feature-card__icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 105, 0.2);
  position: relative;
  z-index: 1;
}

.feature-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  position: relative;
  z-index: 1;
}

.feature-card__title {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.feature-card__desc {
  font-size: 12px;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.feature-card__btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 13px;
  font-weight: 600;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  border: none;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 105, 0.35);
}

.feature-card__btn::after {
  border: none;
}

.feature-card__btn--hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.feature-card--hover {
  opacity: 0.9;
  transform: scale(0.99);
}

.feature-card--growth {
  background: linear-gradient(135deg, #FFF3E6 0%, #FFE4CC 100%);
}

.feature-card__arrow {
  font-size: 40rpx;
  color: #D4A9A0;
  padding-right: 10rpx;
}

/* ===== 菜单分组 ===== */
.menu-group {
  margin-top: 28rpx;
  background: var(--color-white);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx;
}

.menu-item--hover {
  background: var(--color-bg);
}

.menu-item__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.menu-item__icon--orange { background: var(--color-primary-light); }
.menu-item__icon--blue   { background: #E3F2FD; }
.menu-item__icon--red    { background: var(--color-danger-light); }

.menu-item__text {
  flex: 1;
  font-size: 15px;
  color: var(--color-text-primary);
  font-weight: 500;
}

.menu-item__text--danger {
  color: var(--color-danger);
}

.menu-item__arrow {
  font-size: 22px;
  color: var(--color-text-hint);
  font-weight: 300;
  line-height: 1;
  flex-shrink: 0;
}

.menu-divider {
  height: 1rpx;
  background: var(--color-border);
  margin-left: 112rpx;
}

/* ===== 版本号 ===== */
.version-text {
  text-align: center;
  font-size: 12px;
  color: var(--color-text-hint);
  padding: 48rpx 0 24rpx;
}


/* ===== 关于弹窗 ===== */
.about-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1001;
  transition: background 0.28s ease;
  pointer-events: none;
}
.about-mask--show {
  background: rgba(0, 0, 0, 0.45);
  pointer-events: auto;
}

.about-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 36rpx calc(120rpx + env(safe-area-inset-bottom));
  z-index: 1002;
  transform: translateY(100%);
  transition: transform 0.28s ease;
  max-height: 85vh;
  overflow-y: auto;
}
.about-panel--show {
  transform: translateY(0);
}

.about-panel__handle {
  width: 80rpx;
  height: 6rpx;
  background: #E5E7EB;
  border-radius: 3rpx;
  margin: 0 auto 48rpx;
}

.about-panel__header {
  margin-bottom: 32rpx;
  text-align: center;
}
.about-panel__title {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.about-section {
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.about-section:last-child {
  border-bottom: none;
}
.about-section__label {
  display: block;
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}
.about-section__text {
  font-size: 15px;
  color: var(--color-text-primary);
  line-height: 1.6;
}
.about-section__text--copy {
  color: var(--color-primary);
}
.about-link-row {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}
.about-link {
  font-size: 15px;
  color: var(--color-primary);
}
.about-section--disclaimer {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFF8EC;
  border-radius: 16rpx;
  border: none;
}
.about-section__disclaimer {
  font-size: 12px;
  color: #9A6B2E;
  line-height: 1.6;
}

/* ===== 协议弹窗 ===== */
.legal-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1003;
  transition: background 0.28s ease;
  pointer-events: none;
}
.legal-modal-mask--show {
  background: rgba(0, 0, 0, 0.45);
  pointer-events: auto;
}

.legal-modal {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 1004;
  max-height: 82vh;
  background: var(--color-white);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 32rpx 0;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.28s ease;
}
.legal-modal--show {
  transform: translateY(0);
}

.legal-modal__handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 100rpx;
  background: #E4E7EC;
  align-self: center;
  margin: 0 0 24rpx;
}

.legal-modal__header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.legal-modal__title {
  font-size: 20px;
  font-weight: 800;
  color: var(--color-text-primary);
  text-align: center;
}

.legal-modal__content {
  flex: 1;
  min-height: 0;
  max-height: 56vh;
  padding: 24rpx 0;
  box-sizing: border-box;
}

.legal-modal__intro {
  display: block;
  font-size: 14px;
  line-height: 1.7;
  color: var(--color-text-secondary);
  margin-bottom: 28rpx;
}

.legal-section {
  margin-bottom: 30rpx;
}

.legal-section__title {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 14rpx;
}

.legal-section__item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.legal-section__dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 11px;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
  flex-shrink: 0;
  margin-top: 3rpx;
}

.legal-section__text {
  flex: 1;
  font-size: 14px;
  line-height: 1.65;
  color: var(--color-text-secondary);
}

.legal-modal__footer {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.legal-modal__btn {
  border-radius: 100rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 17px;
  font-weight: 700;
  text-align: center;
  padding: 24rpx;
}

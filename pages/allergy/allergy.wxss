/* pages/trace/trace.wxss — 过敏溯源页样式 */

/* ===== 自定义导航栏 ===== */
.page-container {
  min-height: 100vh;
  background: var(--color-bg);
}

.allergy-hero {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 176rpx;
  box-sizing: border-box;
  background: var(--color-primary);
  box-shadow: 0 6rpx 20rpx rgba(255, 140, 105, 0.14);
  z-index: 20;
}

.custom-nav {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  background: transparent;
  border-bottom: none;
  z-index: 10;
  display: flex;
  justify-content: center;
}

.custom-nav__back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.custom-nav__back-text {
  font-size: 52rpx;
  color: var(--color-text-primary);
  font-weight: 300;
  line-height: 1;
}

.custom-nav__title {
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.custom-nav__title--hero {
  color: #fff;
  letter-spacing: 1rpx;
  display: block;
  line-height: 1.2;
}

.custom-nav__placeholder {
  width: 80rpx;
  flex-shrink: 0;
}

.allergy-content {
  position: relative;
  z-index: 2;
  padding-top: 176rpx;
}

/* ===== 醒目过敏入口 ===== */
.allergy-entry {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF4757 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 71, 87, 0.3);
}

.allergy-entry__icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.allergy-entry__icon-text {
  font-size: 36px;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.allergy-entry__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.allergy-entry__title {
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.allergy-entry__desc {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  line-height: 1.4;
}

.allergy-entry__btn {
  background: #FFFFFF;
  color: #FF4757;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  font-size: 14px;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* ===== 表单弹窗 ===== */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.form-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.form-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.28s ease;
  padding: 28rpx 30rpx calc(140rpx + env(safe-area-inset-bottom));
}

.form-panel--show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.form-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.form-panel__title {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.form-panel__close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
}

.form-panel__close-placeholder {
  width: 60rpx;
  flex-shrink: 0;
}

.form-panel__body {
  /* no scroll needed, content is short */
}

.form-panel__footer {
  margin-top: 24rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-field {
  margin-bottom: 20rpx;
}

.form-field__label {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.form-field__picker {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 14rpx 18rpx;
  font-size: 14px;
  font-size: 14px;
  color: var(--color-text-primary);
}

.form-field__textarea {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 14rpx 18rpx;
  font-size: 14px;
  color: var(--color-text-primary);
  width: 100%;
  min-height: 100rpx;
  line-height: 1.5;
}

/* ===== 症状多选 ===== */
.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.symptom-chip {
  padding: 10rpx 22rpx;
  background: var(--color-bg);
  border: 2rpx solid transparent;
  border-radius: 100rpx;
  font-size: 13px;
  color: var(--color-text-secondary);
}

.symptom-chip--default {
  background: var(--color-bg);
  border-color: transparent;
  color: var(--color-text-secondary);
}

.symptom-chip--selected {
  background: var(--color-danger-light);
  border-color: var(--color-danger);
  color: var(--color-danger);
}

.other-symptom-input {
  display: block;
  margin-top: 12rpx;
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
}

/* ===== 严重程度 ===== */
.severity-row {
  display: flex;
  gap: 16rpx;
}

.severity-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx;
  border-radius: var(--border-radius-base);
  font-size: 14px;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border: 2rpx solid transparent;
}

.severity-btn--active {
  color: var(--color-danger);
  background: var(--color-danger-light);
  border-color: var(--color-danger);
}

.form-btn-row {
  display: flex;
  gap: 12rpx;
}

.form-submit-btn {
  flex: 1;
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 15px;
  padding: 18rpx 12rpx;
  margin: 0;
}

.form-submit-btn::after {
  border: none;
}

.form-direct-save-btn {
  flex: 1;
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 100rpx;
  font-size: 15px;
  padding: 18rpx 12rpx;
  margin: 0;
}

.form-direct-save-btn::after {
  border: none;
}

/* ===== 可疑食物分析弹窗 ===== */
.suspect-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.28s ease;
  height: 78vh;
  display: flex;
  flex-direction: column;
}

.suspect-panel--show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.suspect-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 30rpx 16rpx;
  flex-shrink: 0;
}

.suspect-panel__title {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.suspect-panel__close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
}

.suspect-panel__body {
  flex: 1;
  min-height: 0;
  padding: 0 30rpx;
}

.suspect-panel__footer {
  padding: 16rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

/* ===== 可疑食物分析 ===== */
.suspect-section {
  margin: 0 24rpx 20rpx;
}

.suspect-hint {
  font-size: 13px;
  color: var(--color-text-hint);
  display: block;
  margin-bottom: 16rpx;
}

.suspect-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.suspect-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: var(--border-radius-base);
  background: var(--color-bg);
  gap: 14rpx;
  border: 2rpx solid transparent;
}

.suspect-item--high {
  background: var(--color-danger-light);
  border-color: var(--color-danger);
}

.suspect-item--mid {
  background: var(--color-warning-light);
  border-color: var(--color-warning);
}

.suspect-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}

.rank-1 { background: #FFD700; color: #333; }
.rank-2 { background: #C0C0C0; color: #333; }
.rank-3 { background: #CD7F32; color: #fff; }
.rank-other { background: var(--color-bg); color: var(--color-text-hint); }

.suspect-emoji {
  font-size: 56rpx;
  line-height: 1;
  flex-shrink: 0;
}

.suspect-icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
  flex-shrink: 0;
}

.suspect-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.suspect-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}

.suspect-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.suspect-tag {
  padding: 2rpx 10rpx;
  border-radius: 100rpx;
  font-size: 11px;
}

.suspect-time {
  font-size: 11px;
  color: var(--color-text-hint);
}

.suspect-confidence {
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 12px;
  flex-shrink: 0;
}

.suspect-confidence--high { background: var(--color-danger-light); color: var(--color-danger); }
.suspect-confidence--mid { background: var(--color-warning-light); color: var(--color-warning); }
.suspect-confidence--low { background: var(--color-bg); color: var(--color-text-hint); }

/* ===== 确认区 ===== */
.confirm-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.confirm-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 14rpx;
}

.confirm-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.confirm-btn {
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
  font-size: 13px;
  background: var(--color-bg);
  color: var(--color-text-secondary);
}

.confirm-btn--selected {
  background: var(--color-danger-light);
  color: var(--color-danger);
}

.save-allergy-btn {
  width: 100%;
  background: var(--color-danger);
  color: #fff;
  border-radius: 100rpx;
  font-size: 15px;
  padding: 20rpx;
}

.save-allergy-btn::after {
  border: none;
}

/* ===== 过敏历史时间线 ===== */
.history-section {
  margin-top: 28rpx;
  padding-bottom: 160rpx;
}

/* ===== 底部按钮栏 ===== */
.bottom-btn-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  border-radius: 100rpx;
}

.bottom-btn--back {
  flex: 0 0 30%;
  background: #F2F3F5;
  color: #333;
}

.bottom-btn--record {
  background: #FF4757;
  box-shadow: 0 8rpx 24rpx rgba(255, 71, 87, 0.4);
}

.bottom-btn__icon {
  font-size: 22px;
  line-height: 1;
}

.bottom-btn__text {
  font-size: 17px;
  font-weight: 700;
}

.bottom-btn__text--white {
  color: #fff;
}

.empty-state__text {
  font-size: 14px;
  color: var(--color-text-hint);
  display: block;
  text-align: center;
  padding: 60rpx 0;
}

.timeline {
  padding: 0 24rpx;
}

.timeline-item {
  position: relative;
  padding-left: 36rpx;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 18rpx;
  height: 18rpx;
  background: var(--color-danger);
  border-radius: 50%;
}

.timeline-line {
  position: absolute;
  left: 8rpx;
  top: 34rpx;
  width: 2rpx;
  bottom: -24rpx;
  background: var(--color-border);
}

.timeline-content {
  margin: 0;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.timeline-header__right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.timeline-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.timeline-delete__icon {
  width: 32rpx;
  height: 32rpx;
}

.timeline-date {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.timeline-symptom {
  font-size: 14px;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.timeline-food {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.timeline-food-emoji {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.timeline-food-icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
  flex-shrink: 0;
}

.timeline-food-name {
  font-size: 13px;
  color: var(--color-danger);
  font-weight: 500;
}

.timeline-notes {
  font-size: 13px;
  color: var(--color-text-hint);
  display: block;
  margin-bottom: 4rpx;
}

.timeline-retest {
  font-size: 12px;
  color: var(--color-warning);
  display: block;
  margin-top: 4rpx;
}

/* pages/trace/trace.wxss — 日历页样式 */

.page-container {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ===== 日历容器 ===== */
.calendar-container {
  background: var(--color-white);
  padding: 32rpx 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.calendar-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.calendar-nav__btn {
  font-size: 14px;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.calendar-nav__today {
  font-size: 13px;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 100rpx;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 24rpx;
}

.calendar-weekday {
  font-size: 12px;
  color: var(--color-text-hint);
  text-align: center;
  padding: 8rpx 0;
}

/* ===== 日历网格 ===== */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.calendar-day {
  height: 200rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 6rpx 4rpx 4rpx;
  border-radius: 14rpx;
  position: relative;
  background: var(--color-bg);
  border: 2rpx solid transparent;
  overflow: hidden;
}

.calendar-day--other {
  background: transparent;
  border-color: transparent;
  pointer-events: none;
}
.calendar-day--other .calendar-day__num,
.calendar-day--other .calendar-day__empty,
.calendar-day--other .calendar-day__foods {
  display: none;
}

.calendar-day--has-record {
  background: #FFF8F5;
}

.calendar-day__num {
  font-size: 13px;
  color: var(--color-text-primary);
  font-weight: 600;
  line-height: 1;
  margin-bottom: 8rpx;
  text-align: center;
}

.calendar-day__num--today {
  color: var(--color-primary);
  font-weight: 700;
}

.calendar-day__empty {
  font-size: 11px;
  color: var(--color-text-hint);
}

.calendar-day__foods {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  width: 100%;
  align-items: flex-start;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.calendar-day__food {
  display: flex;
  align-items: center;
  gap: 3rpx;
  width: 100%;
  line-height: 1.15;
  flex-shrink: 0;
}

.calendar-day__food-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
  display: block;
}

.calendar-day__food-emoji {
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
}

.calendar-day__food-name {
  font-size: 18rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.calendar-day__more {
  font-size: 18rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 日期详情弹窗 ===== */
.day-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.day-modal-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.day-modal {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  background: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.28s ease;
  height: 70vh;
  display: flex;
  flex-direction: column;
}

.day-modal--show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.day-modal__handle {
  width: 80rpx;
  height: 8rpx;
  background: #DDD;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.day-modal__header {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.day-modal__title {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
}

.day-modal__body {
  flex: 1;
  min-height: 0;
}

.day-modal__list {
  padding: 16rpx 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.day-modal__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.day-modal__icon-box {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.day-modal__food-icon {
  width: 100%;
  height: 100%;
}

.day-modal__emoji {
  font-size: 60rpx;
  line-height: 1;
}

.day-modal__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.day-modal__name {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.day-modal__time {
  font-size: 12px;
  color: var(--color-text-hint);
}

.day-modal__reaction {
  font-size: 12px;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.day-modal__reaction--normal { background: var(--color-success-light); color: var(--color-success); }
.day-modal__reaction--warning { background: var(--color-warning-light); color: var(--color-warning); }
.day-modal__reaction--danger { background: var(--color-danger-light); color: var(--color-danger); }

.day-modal__delete {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.day-modal__delete-icon {
  width: 36rpx;
  height: 36rpx;
}

.scroll-bottom-spacer {
  height: calc(240rpx + env(safe-area-inset-bottom));
}

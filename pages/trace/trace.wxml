<!-- pages/trace/trace.wxml — 日历 -->
<view class="page-container">
  <view class="calendar-container">
    <!-- 日历头部 -->
    <view class="calendar-header">
      <text class="calendar-title">{{calendarYear}}年{{calendarMonth}}月</text>
      <view class="calendar-nav">
        <text class="calendar-nav__btn" bindtap="prevMonth">上月</text>
        <text class="calendar-nav__today" bindtap="goToToday">今天</text>
        <text class="calendar-nav__btn" bindtap="nextMonth">下月</text>
      </view>
    </view>

    <!-- 星期标题 -->
    <view class="calendar-weekdays">
      <text class="calendar-weekday" wx:for="日一二三四五六" wx:key="*this">{{item}}</text>
    </view>

    <!-- 日历网格 -->
    <scroll-view scroll-y class="calendar-scroll" style="height:{{calendarScrollHeight}}px">
      <view class="calendar-grid">
        <view
          class="calendar-day {{item.isCurrentMonth ? '' : 'calendar-day--other'}} {{item.hasRecord ? 'calendar-day--has-record' : ''}}"
          wx:for="{{calendarDays}}"
          wx:key="date"
          bindtap="selectCalendarDay"
          data-date="{{item.date}}"
        >
          <text class="calendar-day__num {{item.isToday ? 'calendar-day__num--today' : ''}}">{{item.day}}</text>
          <view class="calendar-day__foods" wx:if="{{item.dayFoods.length > 0}}">
            <view class="calendar-day__food" wx:for="{{item.dayFoods}}" wx:for-item="food" wx:key="recordTime">
              <image wx:if="{{food.localIconPath}}" src="{{food.localIconPath}}" class="calendar-day__food-icon" mode="aspectFit"></image>
              <image wx:elif="{{food.iconUrl}}" src="{{food.iconUrl}}" class="calendar-day__food-icon" mode="aspectFit"></image>
              <text wx:else class="calendar-day__food-emoji">{{food.emoji}}</text>
              <text class="calendar-day__food-name">{{food.foodName}}</text>
            </view>
            <view class="calendar-day__more" wx:if="{{item.recordCount > 6}}">
              <text>+{{item.recordCount - 6}}更多</text>
            </view>
          </view>
          <text class="calendar-day__empty" wx:elif="{{item.isCurrentMonth}}">—</text>
        </view>
      </view>
      <view class="scroll-bottom-spacer"></view>
    </scroll-view>
  </view>
</view>

<!-- ===== 日期详情弹窗（position:fixed）===== -->
<view class="day-modal-mask {{showDayModal ? 'day-modal-mask--show' : ''}}" wx:if="{{renderSelectedDay}}" bindtap="closeDayModal" catchtouchmove="noop"></view>
<view class="day-modal {{showDayModal ? 'day-modal--show' : ''}}" wx:if="{{renderSelectedDay}}" catchtouchmove="noop" bindtouchstart="onModalDragStart" bindtouchend="onModalDragEnd">
  <view class="day-modal__handle" catchtouchstart="onModalDragStart" catchtouchend="onModalDragEnd"></view>
  <view class="day-modal__header" catchtouchstart="onModalDragStart" catchtouchend="onModalDragEnd">
    <text class="day-modal__title">{{selectedDay.dateText}}</text>
  </view>
  <scroll-view scroll-y class="day-modal__body" style="height:{{dayModalScrollHeight}}px">
    <view class="day-modal__list">
      <view class="day-modal__item" wx:for="{{selectedDay.foods}}" wx:key="id">
        <view class="day-modal__icon-box">
          <image wx:if="{{item.localIconPath}}" src="{{item.localIconPath}}" class="day-modal__food-icon" mode="aspectFit"></image>
          <image wx:elif="{{item.iconUrl}}" src="{{item.iconUrl}}" class="day-modal__food-icon" mode="aspectFit"></image>
          <text wx:else class="day-modal__emoji">{{item.emoji}}</text>
        </view>
        <view class="day-modal__info">
          <text class="day-modal__name">{{item.name || item.foodName}}</text>
          <text class="day-modal__time">{{item.timesStr}}</text>
        </view>
        <view class="day-modal__reaction day-modal__reaction--{{item.reactionClass}}" wx:if="{{item.reactionClass !== 'normal'}}">
          <text>{{item.reaction}}</text>
        </view>
        <view class="day-modal__delete" catchtap="onDeleteDayRecord" data-foodid="{{item.id}}" data-name="{{item.name || item.foodName}}" data-count="{{item.times.length}}">
          <image src="/static/icons/trash.svg" class="day-modal__delete-icon" mode="aspectFit"></image>
        </view>
      </view>
    </view>
    <view class="scroll-bottom-spacer"></view>
  </scroll-view>
</view>

<!-- 记录辅食覆盖层 -->
<record-sheet show="{{showRecordSheet}}" bind:close="onRecordSheetClose" bind:saved="onRecordSaved" />

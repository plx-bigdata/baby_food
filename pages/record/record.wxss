/* pages/record/record.wxss — 辅食记录页样式 */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--color-bg);
}

/* ===== 顶部栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.top-bar__date {
  font-size: 17px;
  color: var(--color-primary);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: var(--color-primary-light);
  border-radius: var(--border-radius-base);
}

.meal-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meal-selector__label {
  font-size: 16px;
  color: var(--color-text-secondary);
  font-weight: 600;
}

.meal-selector__btns {
  display: flex;
  gap: 6rpx;
}

.meal-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: var(--color-bg);
  color: var(--color-text-secondary);
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.meal-btn--active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

/* ===== 分类标签 ===== */
.category-wrap {
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
  padding: 12rpx 16rpx;
}

.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.category-tab {
  padding: 10rpx 20rpx;
  font-size: 13px;
  color: var(--color-text-secondary);
  border-radius: 100rpx;
  border: 2rpx solid transparent;
  background: var(--color-bg);
}

.category-tab--active {
  color: #fff;
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.category-tab__name {
  font-size: 14px;
  font-weight: 500;
}

/* ===== 食物网格 ===== */
.food-grid-scroll {
  flex: 1;
  overflow: hidden;
}

.food-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 24rpx;
}

.food-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-white);
  border-radius: var(--border-radius-base);
  padding: 12rpx 6rpx;
  border: 3rpx solid transparent;
  box-shadow: var(--shadow-sm);
  position: relative;
  transition: all 0.2s;
}

.food-card--selected {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.food-card--first {
  border-color: var(--color-warning);
  background: var(--color-warning-light);
}

.food-card__check {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.food-card__img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-bottom: 6rpx;
}

.food-card__name {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: center;
  line-height: 1.3;
}

.food-card__risk {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  font-size: 10px;
}

.food-card__risk--high { background: var(--color-danger-light); color: var(--color-danger); }
.food-card__risk--mid { background: var(--color-warning-light); color: var(--color-warning); }
.food-card__risk--low { display: none; }

/* ===== 底部已选栏 ===== */
.selected-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-white);
  border-top: 1rpx solid var(--color-border);
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
  z-index: 50;
}

.selected-bar__scroll {
  flex: 1;
  white-space: nowrap;
}

.selected-list {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.selected-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex-shrink: 0;
}

.selected-item__img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 10rpx;
}

.selected-item__name {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.selected-item__remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 26rpx;
  height: 26rpx;
  background: var(--color-danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  line-height: 1;
}

.selected-bar__btn {
  flex-shrink: 0;
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 17px;
  font-weight: 600;
  padding: 20rpx 32rpx;
  white-space: nowrap;
}

.selected-bar__btn::after {
  border: none;
}

/* ===== 记录面板 ===== */
.panel-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.record-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}

.record-panel--show {
  transform: translateY(0);
}

.record-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-panel__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.record-panel__close {
  font-size: 18px;
  color: var(--color-text-hint);
  padding: 8rpx;
}

/* ===== 已选食物摘要 ===== */
.selected-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx;
  margin-bottom: 24rpx;
}

.selected-summary__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-white);
  border-radius: 100rpx;
  padding: 6rpx 12rpx;
}

.selected-summary__img {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
}

.selected-summary__name {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.selected-summary__first {
  background: var(--color-warning-light);
  color: var(--color-warning);
  font-size: 11px;
  padding: 2rpx 8rpx;
  border-radius: 100rpx;
}

/* ===== 表单字段 ===== */
.field {
  margin-bottom: 24rpx;
}

.field__label {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.field__picker {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx 20rpx;
  font-size: 16px;
  color: var(--color-text-primary);
}

.field__textarea {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx 20rpx;
  font-size: 14px;
  color: var(--color-text-primary);
  width: 100%;
  min-height: 80rpx;
  line-height: 1.5;
}

/* ===== 选项按钮 ===== */
.option-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.option-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  border-radius: var(--border-radius-base);
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border: 2rpx solid transparent;
}

.option-btn--active {
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-color: var(--color-primary);
}

.option-btn--active.option-btn--warning {
  color: var(--color-warning);
  background: var(--color-warning-light);
  border-color: var(--color-warning);
}

.option-btn--active.option-btn--danger {
  color: var(--color-danger);
  background: var(--color-danger-light);
  border-color: var(--color-danger);
}

/* ===== 保存按钮 ===== */
.save-btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 18px;
  font-weight: 600;
  padding: 28rpx;
  margin-top: 8rpx;
}

.save-btn::after {
  border: none;
}

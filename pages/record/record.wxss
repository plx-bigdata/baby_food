/* pages/record/record.wxss — 辅食记录页（底部弹出样式） */

/* ===== 整体页面包裹 ===== */
.page-wrapper {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: transparent;
}

/* 顶部透明遮罩 */
.sheet-mask {
  flex: 1;
  min-height: 60rpx;
}

/* ===== 底部面板 ===== */
.sheet-body {
  position: relative;
  z-index: 1010;
  height: 88vh;
  background: var(--color-bg);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.12);
  animation: slideUp 0.3s ease-out;
}

.sheet-body--closing {
  animation: slideDown 0.28s ease-in forwards;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes slideDown {
  from { transform: translateY(0); }
  to { transform: translateY(100%); }
}

/* 拖拽手柄 */
.sheet-handle-row {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 100rpx;
}

/* ===== 分类标签 ===== */
.category-wrap {
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
  padding: 12rpx 16rpx;
}

.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.category-tab {
  padding: 10rpx 20rpx;
  font-size: 13px;
  color: var(--color-text-secondary);
  border-radius: 100rpx;
  background: var(--color-bg);
}

.category-tab--active {
  color: #fff;
  background: var(--color-primary);
}

.category-tab__name {
  font-size: 14px;
  font-weight: 500;
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.search-bar__icon {
  font-size: 14px;
  color: var(--color-text-hint, #9CA3AF);
  flex-shrink: 0;
}

.search-bar__input {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg);
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 14px;
}

.search-bar__clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-hint, #9CA3AF);
  font-size: 14px;
  flex-shrink: 0;
}

/* ===== 自定义食物输入 ===== */
.custom-input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.custom-food-input {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg);
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 14px;
}

.custom-add-btn {
  width: 96rpx;
  height: 64rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 32rpx;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ===== 食物网格 ===== */
.food-grid-scroll {
  flex: 1;
  min-height: 0;
}

.food-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 16rpx;
  align-items: stretch;
}

.food-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-white);
  border-radius: 24rpx;
  padding: 12rpx 8rpx;
  border: 1rpx solid rgba(0,0,0,0.08);
  position: relative;
  min-height: 140rpx;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.food-card--selected {
  border-color: var(--color-primary);
  background: #FFF5F2;
}

.food-card__emoji {
  font-size: 80rpx;
  line-height: 1;
  text-align: center;
  flex-shrink: 0;
  margin-bottom: 6rpx;
}

.food-card__icon {
  width: 80rpx;
  height: 80rpx;
  display: block;
  flex-shrink: 0;
  margin-bottom: 6rpx;
}


.food-card__name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* ===== 底部已选栏 ===== */
.selected-bar {
  background: var(--color-white);
  border-top: 1rpx solid var(--color-border);
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.selected-bar__scroll {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
}

.selected-list {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.selected-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex-shrink: 0;
  width: 100rpx;
  min-width: 100rpx;
}

.selected-item__emoji {
  font-size: 56rpx;
  line-height: 1;
  flex-shrink: 0;
}

.selected-item__icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
  flex-shrink: 0;
}

.selected-item__name {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.selected-item__remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 26rpx;
  height: 26rpx;
  background: var(--color-danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  line-height: 1;
}

.selected-bar__btn {
  flex-shrink: 0;
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 15px;
  font-weight: 600;
  padding: 16rpx 24rpx;
  white-space: nowrap;
}

/* ===== 记录面板 ===== */
.panel-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 4999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.28s ease;
}

.panel-mask--show {
  opacity: 1;
  pointer-events: auto;
}

.record-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-white);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 5000;
  transform: translateY(100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.28s ease, opacity 0.28s ease;
  max-height: 80vh;
}

.record-panel--show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.record-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-panel__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.record-panel__close {
  font-size: 28rpx;
  color: var(--color-text-hint);
  padding: 8rpx;
}

/* ===== 已选食物摘要 ===== */
.selected-summary-scroll {
  margin-bottom: 24rpx;
}

.selected-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx;
}

.selected-summary__item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-white);
  border-radius: 100rpx;
  padding: 6rpx 12rpx;
}

.selected-summary__emoji {
  font-size: 64rpx;
  line-height: 1;
  flex-shrink: 0;
}

.selected-summary__icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
  flex-shrink: 0;
}


.selected-summary__name {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.selected-summary__tag {
  font-size: 11px;
  padding: 2rpx 8rpx;
  border-radius: 100rpx;
  margin-left: 4rpx;
}

.selected-summary__tag--safe { background: var(--color-success-light); color: var(--color-success); }
.selected-summary__tag--danger { background: var(--color-danger-light); color: var(--color-danger); }
.selected-summary__tag--testing { background: var(--color-warning-light); color: var(--color-warning); }

/* ===== 表单字段 ===== */
.field-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.field {
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.field--half {
  flex: 1;
  margin-bottom: 0;
}

.field__label {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.field__picker {
  background: var(--color-bg);
  border-radius: var(--border-radius-base);
  padding: 16rpx 20rpx;
  font-size: 16px;
  color: var(--color-text-primary);
}

/* ===== 保存按钮 ===== */
.save-btn {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: calc(32rpx + constant(safe-area-inset-bottom));
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-primary);
  color: #fff;
  border-radius: 100rpx;
  font-size: 18px;
  font-weight: 600;
  padding: 28rpx;
  text-align: center;
  z-index: 1003;
}

<!-- pages/record/record.wxml — 辅食记录页（底部弹出样式） -->
<page-meta background-color="#00000000" />
<view class="page-wrapper">

  <!-- 顶部透明遮罩，点击关闭 -->
  <view class="sheet-mask" bindtap="goBack"></view>

  <!-- 底部面板 -->
  <view class="sheet-body {{closing ? 'sheet-body--closing' : ''}}" bindtouchmove="noop">

    <!-- 拖拽手柄 — 下滑关闭 -->
    <view class="sheet-handle-row" bindtouchstart="onSheetDragStart" bindtouchmove="onSheetDragMove" bindtouchend="onSheetDragEnd" bindtouchcancel="onSheetDragEnd">
      <view class="sheet-handle"></view>
    </view>

    <!-- 分类标签栏 -->
    <view class="category-wrap">
      <view class="category-tabs">
        <view
          class="category-tab {{currentCategory === item.id ? 'category-tab--active' : ''}}"
          wx:for="{{categoryTabs}}"
          wx:key="id"
          bindtap="switchCategory"
          data-id="{{item.id}}"
        >
          <text class="category-tab__name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 搜索框 -->
    <view class="search-bar">
      <text class="search-bar__icon">🔍</text>
      <input
        class="search-bar__input"
        placeholder="搜索食物名称"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view class="search-bar__clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
    </view>

    <!-- 自定义食物输入区 -->
    <view class="custom-input-bar" wx:if="{{currentCategory === 'custom'}}">
      <input
        class="custom-food-input"
        placeholder="输入食物名称"
        value="{{newCustomFoodName}}"
        bindinput="onCustomFoodNameInput"
        confirm-type="done"
        bindconfirm="addCustomFood"
        maxlength="20"
      />
      <view class="custom-add-btn" bindtap="addCustomFood">添加</view>
    </view>

    <!-- 食物网格 -->
    <scroll-view
      scroll-y="{{true}}"
      class="food-grid-scroll"
      bindscroll="onFoodGridScroll"
      bindtouchstart="onFoodGridDragStart"
      bindtouchend="onFoodGridDragEnd"
      bindscrolltoupper="onFoodGridScrollUpper"
    >
      <view class="food-grid">
        <view
          class="{{foodClassMap[item.id] || 'food-card'}}"
          wx:for="{{displayFoods}}"
          wx:key="id"
          bindtap="selectFood"
          data-id="{{item.id}}"
        >
          <image wx:if="{{item.localIconPath}}" class="food-card__icon" src="{{item.localIconPath}}" mode="aspectFit"></image>
          <image wx:elif="{{item.iconUrl}}" class="food-card__icon" src="{{item.iconUrl}}" mode="aspectFit"></image>
          <text wx:else class="food-card__emoji">{{item.emoji}}</text>
          <text class="food-card__name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部已选栏 -->
    <view class="selected-bar" wx:if="{{hasSelected}}">
      <scroll-view scroll-x="{{true}}" class="selected-bar__scroll">
        <view class="selected-list">
          <view class="selected-item" wx:for="{{selectedFoods}}" wx:key="id" bindtap="removeFood" data-id="{{item.id}}">
            <image wx:if="{{item.localIconPath}}" class="selected-item__icon" src="{{item.localIconPath}}" mode="aspectFit"></image>
            <image wx:elif="{{item.iconUrl}}" class="selected-item__icon" src="{{item.iconUrl}}" mode="aspectFit"></image>
            <text wx:else class="selected-item__emoji">{{item.emoji}}</text>
            <text class="selected-item__name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="selected-bar__btn" bindtap="openRecordPanel">
        记录 {{selectedFoods.length}} 种食物
      </view>
    </view>

  </view>
</view>

<!-- 记录面板（z-index 在 sheet 上方） -->
<view class="panel-mask {{showRecordPanel ? 'panel-mask--show' : ''}}" wx:if="{{renderRecordPanel}}" bindtap="closeRecordPanel" catchtouchmove="noop"></view>
<view class="record-panel {{showRecordPanel ? 'record-panel--show' : ''}}" wx:if="{{renderRecordPanel}}" bindtouchstart="onRecordPanelDragStart" bindtouchmove="onSheetDragMove" bindtouchend="onRecordPanelDragEnd">
  <view class="panel-handle"></view>
  <view class="record-panel__header">
    <text class="record-panel__title">确认记录</text>
  </view>

  <!-- 已选食物摘要 -->
  <view class="selected-summary-scroll">
    <view class="selected-summary">
      <view class="selected-summary__item" wx:for="{{selectedFoods}}" wx:key="id">
        <image wx:if="{{item.localIconPath}}" class="selected-summary__icon" src="{{item.localIconPath}}" mode="aspectFit"></image>
        <image wx:elif="{{item.iconUrl}}" class="selected-summary__icon" src="{{item.iconUrl}}" mode="aspectFit"></image>
        <text wx:else class="selected-summary__emoji">{{item.emoji}}</text>
        <text class="selected-summary__name">{{item.name}}</text>
        <view class="selected-summary__tag selected-summary__tag--{{foodDayLabelMap[item.id].type}}">
          {{foodDayLabelMap[item.id].label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 日期和时间 -->
  <view class="field-row">
    <view class="field field--half">
      <text class="field__label">日期</text>
      <picker mode="date" value="{{today}}" bindchange="onDateChange">
        <view class="field__picker">{{today}}</view>
      </picker>
    </view>
    <view class="field field--half">
      <text class="field__label">时间</text>
      <picker mode="time" value="{{recordForm.time}}" bindchange="onTimeChange">
        <view class="field__picker">{{recordForm.time}}</view>
      </picker>
    </view>
  </view>

  <!-- 保存 -->
  <view class="save-btn" bindtap="saveRecord">
    {{saving ? '保存中...' : '保存记录'}}
  </view>
</view>

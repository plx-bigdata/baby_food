/* custom-tab-bar/index.wxss — 自定义底部导航样式 */

.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar--hidden {
  display: none;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 10rpx;
}

.tabbar-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.tabbar-icon {
  width: 64rpx;
  height: 64rpx;
}

/* 选中态背景已移除 —— 四个 tab 均为 emoji 图标,选中靠字号放大 + 文字高亮区分 */

/* 中间记录按钮特殊处理 */
.tabbar-item--record {
  position: relative;
}

.tabbar-item--record .tabbar-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: #FF8C69;
  border-radius: 50%;
  position: relative;
  top: -30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(255, 140, 105, 0.3);
}

.tabbar-item--record .tabbar-icon {
  width: 80rpx;
  height: 80rpx;
}

/* 中间按钮的加号 */
.record-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-btn__plus {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

.record-btn__plus-h {
  width: 44rpx;
  height: 8rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.record-btn__plus-v {
  width: 8rpx;
  height: 44rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.tabbar-icon-emoji {
  font-size: 44rpx;
  line-height: 1;
  opacity: 0.7;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.tabbar-icon-emoji--active {
  opacity: 1;
  transform: scale(1.15);
}

.tabbar-text {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.tabbar-item--active .tabbar-text {
  color: #FF8C69;
  font-weight: 600;
}
